            "pages": ["deployment/docker", "deployment/environment", "deployment/production"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Users",
            "pages": ["api-reference/users/create-user", "api-reference/users/get-users"]
