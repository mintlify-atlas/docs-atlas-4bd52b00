{
  "$schema": "https://mintlify.com/docs.json",
  "name": "App CR",
  "theme": "palm",
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#2563eb"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Celaya55/app-cr"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Celaya55/app-cr"
    }
  },
  "navigation": {
